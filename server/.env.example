PORT=5000
MONGODB_URI=mongodb://localhost:27017/talentlensai
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRE=7d

# AI Configuration (Groq API Key is required for candidate analysis/assessments)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=

# Cloudinary Configuration (Optional, falls back to local disk storage if left blank)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Email Configuration (Optional, falls back to console logging if left blank)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@talentlensai.com
FROM_NAME=TalentLens AI
